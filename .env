# LLM Provider API Keys
# Copy this file to .env and fill in your actual API keys
# Local OpenAI-compatible gateway
OPENAI_COMPAT_BASE_URL=http://localhost:8317/v1
OPENAI_COMPAT_API_KEY=your-api-key-1
OPENAI_COMPAT_MODEL=gemini-3.1-pro-low(auto)

# Google Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIzaSyB5r9BCvKEth6tYjOxQx2LN1Spaif4VlXs

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic Claude API Key (get from https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Social Media Credentials (for browser automation)
# X (Twitter)
X_USERNAME=your-x-username
X_PASSWORD=your-x-password

# Reddit
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password
