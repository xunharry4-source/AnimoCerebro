    def _determine_reflection_depth(self, context: Dict[str, Any]) -> ReflectionDepth:
        """确定反思深度"""
        complexity = context.get("complexity", "medium")
        impact = context.get("impact", "medium")
        
        if complexity == "high" or impact == "high":
            return ReflectionDepth.SYSTEMIC
        elif complexity == "medium" or impact == "medium":
            return ReflectionDepth.STRATEGIC
        else:
            return ReflectionDepth.ANALYTICAL
    
    def _assess_reflection_quality(self, content: Dict[str, Any]) -> ReflectionQuality:
        """评估反思质量"""
        score = 0
        
        # 检查内容完整性
        if content.get("summary"):
            score += 1
        if content.get("insights"):
            score += 1
        if content.get("lessons"):
            score += 1
        if content.get("improvements"):
            score += 1
        
        # 检查内容质量
        if len(content.get("insights", [])) >= 2:
            score += 1
        if len(content.get("lessons", [])) >= 2:
            score += 1
        
        if score >= 5:
            return ReflectionQuality.EXCELLENT
        elif score >= 4:
            return ReflectionQuality.GOOD
        elif score >= 2:
            return ReflectionQuality.FAIR
        else:
            return ReflectionQuality.POOR
    
    # 反思管理方法
    def get_reflection(self, reflection_id: str) -> ReflectionRecord:
        """获取反思记录"""
        # 先从缓存查找
        if reflection_id in self._reflection_cache:
            return self._reflection_cache[reflection_id]
        
        # 从持久化层查找
        if self.persistence:
            reflection = self.persistence.get_reflection(reflection_id)
            if reflection:
                self._reflection_cache[reflection_id] = reflection
                return reflection
        
        raise ReflectionNotFoundError(f"Reflection not found: {reflection_id}")
    
    def list_reflections(self, filters: Optional[Dict[str, Any]] = None) -> List[ReflectionRecord]:
        """列出反思记录"""
        if self.persistence:
            reflections_data = self.persistence.query_reflections(filters or {})
            return reflections_data  # 直接返回列表
        else:
            # 从缓存返回
            reflections = list(self._reflection_cache.values())
            
            # 应用过滤
            if filters:
                reflections = [r for r in reflections if self._matches_filters(r, filters)]
            
            return reflections
    
    def update_reflection(self, reflection_id: str, updates: Dict[str, Any]) -> ReflectionRecord:
        """更新反思记录"""
        reflection = self.get_reflection(reflection_id)
        
        # 更新字段
        locked_items = []
        for field, value in updates.items():
            if field == "reflection_list" and isinstance(value, list):
                # Filter out modifications to immutable items
                current_items = {item.item_id: item for item in reflection.reflection_list}
                new_items = []
                for item_data in value:
                    if isinstance(item_data, dict):
                        iid = item_data.get("item_id")
                        if iid in current_items and current_items[iid].is_immutable:
                            # Restore original for immutable items
                            new_items.append(current_items[iid])
                            locked_items.append(iid)
                        else:
                            new_items.append(ReflectionItem.model_validate(item_data))
                    elif isinstance(item_data, ReflectionItem):
                         if item_data.item_id in current_items and current_items[item_data.item_id].is_immutable:
                             new_items.append(current_items[item_data.item_id])
                             locked_items.append(item_data.item_id)
                         else:
                             new_items.append(item_data)
                reflection.reflection_list = new_items
            elif hasattr(reflection, field):
                setattr(reflection, field, value)
        
        if locked_items:
            logger.warning(f"Attempted to modify immutable items {locked_items} in reflection {reflection_id}. Changes ignored.")

        reflection.updated_at = datetime.now(timezone.utc)
        
        # 保存更新
        if self.persistence:
            self.persistence.save_reflection(reflection)
        
        # 更新缓存
        self._reflection_cache[reflection_id] = reflection
        
        logger.info(f"Updated reflection: {reflection_id}")
        return reflection
    
    def delete_reflection(self, reflection_id: str) -> bool:
        """删除反思记录"""
        try:
            if self.persistence:
                success = self.persistence.delete_reflection(reflection_id)
            else:
                success = reflection_id in self._reflection_cache
            
            if success:
                self._reflection_cache.pop(reflection_id, None)
                logger.info(f"Deleted reflection: {reflection_id}")
            
            return success
            
        except Exception as e:
            logger.error(f"Failed to delete reflection {reflection_id}: {e}")
            return False
    
    # 模板管理
    def create_template(self, name: str, description: str, template_data: Dict[str, Any]) -> ReflectionTemplate:
        """创建反思模板"""
        template = ReflectionTemplate(
            template_id=f"template_{uuid4().hex[:8]}",
            name=name,
            description=description,
            **template_data
        )
        
        if self.persistence:
            self.persistence.save_template(template)
        
        self._template_cache[template.template_id] = template
        
        logger.info(f"Created template: {template.template_id}")
        return template
    
    def get_template(self, template_id: str) -> Optional[ReflectionTemplate]:
        """获取模板"""
        if template_id in self._template_cache:
            return self._template_cache[template_id]
        
        if self.persistence:
            template = self.persistence.get_template(template_id)
            if template:
                self._template_cache[template_id] = template
                return template
        
        return None
    
    def list_templates(self) -> List[ReflectionTemplate]:
        """列出所有模板"""
        if self.persistence:
            templates_data = self.persistence.load_templates()
            return list(templates_data.values())
        else:
            return list(self._template_cache.values())
    
    # 治理方法
    def verify_reflection(self, reflection_id: str, verified_by: str) -> ReflectionRecord:
        """验证反思"""
        reflection = self.get_reflection(reflection_id)
        
        reflection.governance_status = GovernanceStatus.VERIFIED
        reflection.verified_at = datetime.now(timezone.utc)
        reflection.verified_by = verified_by
        
        return self.update_reflection(reflection_id, {
            "governance_status": GovernanceStatus.VERIFIED,
            "verified_at": reflection.verified_at,
            "verified_by": verified_by
        })
    
    def mark_suspect(self, reflection_id: str, reason: str) -> ReflectionRecord:
        """标记为可疑"""
        reflection = self.get_reflection(reflection_id)
        
        reflection.governance_status = GovernanceStatus.SUSPECT
        reflection.metadata["suspect_reason"] = reason
        
        return self.update_reflection(reflection_id, {
            "governance_status": GovernanceStatus.SUSPECT,
            "metadata": reflection.metadata
        })
    
    def archive_reflection(self, reflection_id: str) -> ReflectionRecord:
        """归档反思"""
        reflection = self.get_reflection(reflection_id)
        
        reflection.governance_status = GovernanceStatus.ARCHIVED
        
        return self.update_reflection(reflection_id, {
            "governance_status": GovernanceStatus.ARCHIVED
        })
    
    # 统计方法
    def get_metrics(self) -> ReflectionMetrics:
        """获取反思指标"""
        reflections = self.list_reflections()
        
        metrics = ReflectionMetrics()
        metrics.total_reflections = len(reflections)
        
        # 按类型统计
        type_counts = {}
        depth_counts = {}
        quality_counts = {}
        governance_counts = {}
        
        total_confidence = 0
        total_impact = 0
        total_actionability = 0
        
        today = datetime.now(timezone.utc).date()
        from datetime import timedelta
        week_ago = today - timedelta(days=7)
        month_ago = today.replace(day=1)
        
        for reflection in reflections:
            # 类型统计
            type_counts[reflection.reflection_type.value] = type_counts.get(reflection.reflection_type.value, 0) + 1
            
            # 深度统计
            depth_counts[reflection.depth.value] = depth_counts.get(reflection.depth.value, 0) + 1
            
            # 质量统计
            quality_counts[reflection.quality.value] = quality_counts.get(reflection.quality.value, 0) + 1
            
            # 治理状态统计
            governance_counts[reflection.governance_status.value] = governance_counts.get(reflection.governance_status.value, 0) + 1
            
            # 累计指标
            total_confidence += reflection.confidence
            total_impact += reflection.impact_score
            total_actionability += reflection.actionability
            
            # 时间统计
            if reflection.created_at.date() == today:
                metrics.reflections_today += 1
            if reflection.created_at.date() >= week_ago:
                metrics.reflections_this_week += 1
            if reflection.created_at.date() >= month_ago:
                metrics.reflections_this_month += 1
            
            # 治理统计
            if reflection.governance_status == GovernanceStatus.VERIFIED:
                metrics.verified_reflections += 1
            elif reflection.governance_status == GovernanceStatus.SUSPECT:
                metrics.suspect_reflections += 1
            elif reflection.governance_status == GovernanceStatus.ARCHIVED:
                metrics.archived_reflections += 1
        
        # 设置统计数据
        metrics.reflections_by_type = type_counts
        metrics.reflections_by_depth = depth_counts
        metrics.reflections_by_quality = quality_counts
        
        # 计算平均值
        if reflections:
            metrics.average_confidence = total_confidence / len(reflections)
            metrics.average_impact_score = total_impact / len(reflections)
            metrics.average_actionability = total_actionability / len(reflections)
        
        # 保存指标
        if self.persistence:
            self.persistence.save_metrics(metrics)
        
        return metrics
    
    def _matches_filters(self, reflection: ReflectionRecord, filters: Dict[str, Any]) -> bool:
        """检查反思是否匹配过滤条件"""
        # 实现过滤逻辑（与persistence层相同）
        for key, value in filters.items():
            if hasattr(reflection, key):
                if getattr(reflection, key) != value:
                    return False
        return True
    
