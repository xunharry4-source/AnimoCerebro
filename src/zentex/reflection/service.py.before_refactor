    def __init__(
        self, 
        persistence: Optional[ReflectionPersistence] = None,
        llm_temperature: float = 0.3,
        llm_max_tokens: int = 2048
    ) -> None:
        """
        初始化反思服务
        
        Zentex规范：反思是核心认知算子，必须使用LLM，不允许规则引擎fallback。
        
        Args:
            persistence: 持久化层实例
            llm_temperature: LLM采样温度（0-1，越低越确定）
            llm_max_tokens: LLM最大输出token数
            
        Raises:
            ReflectionGenerationError: LLM初始化失败时抛出（fail-closed）
        """
        self.persistence = persistence
        self._reflection_cache: Dict[str, ReflectionRecord] = {}
        self._template_cache: Dict[str, ReflectionTemplate] = {}
        
        # Zentex规范：必须初始化LLM生成器，失败则抛出异常
        try:
            self._llm_generator = LLMReflectionGenerator(
                temperature=llm_temperature,
                max_tokens=llm_max_tokens
            )
            logger.info(f"ReflectionService initialized with mandatory LLM (temp={llm_temperature}, max_tokens={llm_max_tokens})")
        except Exception as e:
            # Fail-closed：LLM不可用时直接失败，不允许降级
            logger.error(f"Failed to initialize mandatory LLM for reflection: {e}")
            raise ReflectionGenerationError(
                f"Reflection service requires LLM but initialization failed: {e}. "
                f"Please check LLM configuration, API keys, and network connectivity."
            )
        
        self.outcome_binding = OutcomeBinding()
        
        # 初始化默认模板
        self._initialize_default_templates()
        
        logger.info("ReflectionService initialized successfully with mandatory LLM")
    
    def generate_reflection(
        self,
        subject: str,
        reflection_type: ReflectionType,
        context: Dict[str, Any],
        trigger: ReflectionTrigger = ReflectionTrigger.AUTOMATIC,
        trace_id: Optional[str] = None,
        session_id: Optional[str] = None,
        template_id: Optional[str] = None
    ) -> ReflectionRecord:
        """
        生成反思记录
        
        Args:
            subject: 反思主题
            reflection_type: 反思类型
            context: 反思上下文
            trigger: 触发器
            trace_id: 追踪ID
            session_id: 会话ID
            template_id: 模板ID
            
        Returns:
            生成的反思记录
        """
        try:
            # 获取模板
            template = None
            if template_id:
                template = self.get_template(template_id)
            
            # 生成反思内容
            reflection_content = self._generate_reflection_content(
                subject, reflection_type, context, template
            )
            
            # 创建反思记录
            reflection = ReflectionRecord(
                reflection_id=create_reflection_id(),
                trace_id=trace_id,
                session_id=session_id,
                reflection_type=reflection_type,
                depth=self._determine_reflection_depth(context),
                quality=self._assess_reflection_quality(reflection_content),
                trigger=trigger,
                reflection_timestamp=datetime.now(timezone.utc),
                subject=subject,
                context=context,
                **reflection_content
            )
            
            # Post-process content to fill reflection_list (仅首次生成时执行)
            self._sync_legacy_to_list(reflection)
            
            # 添加核心固定项目（如果不存在）
            self._ensure_core_fixed_items(reflection)
            
            # 添加元反思审计项目
            meta_item = self._generate_meta_audit_item(reflection)
            reflection.reflection_list.append(meta_item)
            
            # 反向同步以确保在旧版UI中可见
            self._sync_list_to_legacy(reflection)
            
            # 保存反思
            if self.persistence:
                self.persistence.save_reflection(reflection)
            
            # 更新缓存
            self._reflection_cache[reflection.reflection_id] = reflection
            
            logger.info(f"Generated reflection: {reflection.reflection_id}")
            return reflection
            
        except Exception as e:
            logger.error(f"Failed to generate reflection: {e}")
            raise ReflectionGenerationError(f"Reflection generation failed: {e}")

    def register_expectation(self, target_state: str, criteria: List[str], confidence: float = 0.5) -> str:
        """Helper to register an expectation through the service."""
        exp = self.outcome_binding.register_expectation(target_state, criteria, confidence)
        return exp.expectation_id

    def process_outcome(self, expectation_id: str, actual_state: str, metrics: Dict[str, Any]) -> Any:
        """
        Process a real outcome, compare with expectation, and generate a reflection.
        """
        result = self.outcome_binding.collect_result(expectation_id, actual_state, metrics)
        deviation = self.outcome_binding.compare(result)
        
        # Generate an OUTCOME_REFLECTION using the deviation analysis
        reflection = self.generate_reflection(
            subject=f"Outcome Analysis for {expectation_id}",
            reflection_type=ReflectionType.OUTCOME_REFLECTION,
            context={
                "expectation_id": expectation_id,
                "result_id": result.result_id,
                "deviation": deviation.model_dump(),
                "metrics": metrics
            }
        )
        
        # GrowthWriter injection point (pseudo-code/logic)
        if deviation.deviation_score > 0.3:
             logger.info(f"Significant deviation ({deviation.deviation_score}) detected. Growth feedback triggered.")
             # TODO: Trigger identity pattern update
             
        return reflection
    
    def _generate_reflection_content(
        self, 
        subject: str, 
        reflection_type: ReflectionType, 
        context: Dict[str, Any],
        template: Optional[ReflectionTemplate] = None
    ) -> Dict[str, Any]:
        """
        生成反思内容
        
        Zentex规范：反思是核心认知算子，必须使用LLM。不允许规则引擎fallback。
        
        Args:
            subject: 反思主题
            reflection_type: 反思类型
            context: 上下文数据
            template: 可选的反思模板（当前未使用，保留用于未来扩展）
            
        Returns:
            包含summary, insights, lessons等的字典
            
        Raises:
            ReflectionGenerationError: LLM调用失败时抛出（fail-closed行为）
        """
        # Zentex规范：直接调用LLM，无fallback
        logger.debug(f"Generating reflection using mandatory LLM for: {subject}")
        
        return self._llm_generator.generate_reflection(
            subject=subject,
            reflection_type=reflection_type,
            context=context
        )
    
