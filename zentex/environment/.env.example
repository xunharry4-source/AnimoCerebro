# G19 - 用户偏好辨析与意图对齐模块配置
# 复制此文件为 .env 并填写实际值

# ===========================================================================
# 数据库配置
# ===========================================================================

# 数据库后端类型 (sqlite/postgresql)
G19_DATABASE_BACKEND=sqlite

# SQLite 数据库文件路径
G19_SQLITE_DB_PATH=app_data/g19_preference_store.db

# PostgreSQL 连接字符串（仅当 backend=postgresql 时使用）
# G19_POSTGRESQL_URL=postgresql://user:password@localhost:5432/g19_db

# 启用 SQLite WAL 模式以提升并发性能
G19_ENABLE_WAL_MODE=true

# 数据库连接池大小
G19_CONNECTION_POOL_SIZE=5

# ===========================================================================
# 判定引擎配置
# ===========================================================================

# 自动确认偏好的置信度阈值 (0.0-1.0)
G19_AUTO_CONFIRM_THRESHOLD=0.9

# 用户确认超时时间（小时）
G19_CONFIRMATION_TIMEOUT_HOURS=24

# 每用户最大待确认案例数
G19_MAX_PENDING_CASES_PER_USER=100

# ===========================================================================
# LLM 配置（用于智能判定）
# ===========================================================================

# LLM 提供商 (openai/anthropic/gemini/ollama)
G19_LLM_PROVIDER=openai

# LLM API 密钥（必需，除非使用 Ollama）
# 从环境变量或 secret manager 加载，不要硬编码
G19_LLM_API_KEY=sk-your-api-key-here

# LLM 模型名称
G19_LLM_MODEL_NAME=gpt-4o-mini

# LLM 温度参数（越低越确定，0.0-1.0）
G19_LLM_TEMPERATURE=0.2

# LLM 调用最大重试次数
G19_LLM_MAX_RETRIES=3

# LLM 调用超时时间（秒）
G19_LLM_TIMEOUT_SECONDS=30

# Ollama 服务地址（仅当 provider=ollama 时使用）
G19_OLLAMA_BASE_URL=http://localhost:11434

# ===========================================================================
# 极端信号拦截配置
# ===========================================================================

# 需要二次确认的风险阈值 (0.0-1.0)
G19_RISK_CONFIRMATION_THRESHOLD=0.7

# 标记为潜在恶意的风险阈值 (0.0-1.0)
G19_RISK_MALICIOUS_THRESHOLD=0.8

# 立即阻断的风险阈值 (0.0-1.0)
G19_RISK_BLOCK_THRESHOLD=0.9

# ===========================================================================
# 攻击检测配置
# ===========================================================================

# 攻击模式相似度阈值 (0.0-1.0)
G19_ATTACK_SIMILARITY_THRESHOLD=0.85

# 攻击模式缓存大小
G19_ATTACK_PATTERN_CACHE_SIZE=1000

# 攻击样本保留天数
G19_ATTACK_SAMPLE_RETENTION_DAYS=365

# ===========================================================================
# 日志与监控配置
# ===========================================================================

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
G19_LOG_LEVEL=INFO

# 启用审计日志
G19_ENABLE_AUDIT_LOGGING=true

# 审计日志文件路径（None=写入 BrainTranscriptStore）
# G19_AUDIT_LOG_PATH=logs/g19_audit.log

# ===========================================================================
# 性能优化配置
# ===========================================================================

# 启用缓存层
G19_ENABLE_CACHE=true

# 缓存 TTL（秒）
G19_CACHE_TTL_SECONDS=300

# 启用异步任务处理
G19_ENABLE_ASYNC_PROCESSING=true

# ===========================================================================
# 安全配置
# ===========================================================================

# 加密敏感数据（如信号内容哈希）
G19_ENCRYPT_SENSITIVE_DATA=true

# 加密密钥（生产环境应从 secret manager 加载）
# G19_ENCRYPTION_KEY=your-encryption-key-here

# 最大信号长度限制
G19_MAX_SIGNAL_LENGTH=10000
